MYSQL_ROOT_PASSWORD=<set_strong_mysql_root_password>
MYSQL_DATABASE=<set_mysql_database_name>

DB_HOST=<set_db_host>
DB_USER=<set_db_user>
DB_PASSWORD=<set_db_password>
DB_NAME=<set_db_name>
DB_PORT=3306
DB_TIMEZONE=+07:00
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000
DB_POOL_EVICT_MS=1000
DB_RETRY_MAX=3
DB_RETRY_BACKOFF_MS=100
DB_RETRY_BACKOFF_EXPONENT=1.5

PORT=<set_backend_port>
JWT_SECRET=<set_long_random_jwt_secret>
DATA_ENCRYPTION_KEY=<set_32_byte_data_encryption_key>
HASH_PEPPER=<set_hash_pepper>
PRIVATE_KEY_ENCRYPTION_KEY=<set_64_hex_chars_for_private_key_encryption>

SESSION_COOKIE_CROSS_SITE=<true_or_false>
SESSION_COOKIE_DOMAIN=<set_cookie_domain_or_leave_empty>
LOG_LEVEL=info
SOCKET_SLOW_THRESHOLD_MS=300

FRONTEND_ORIGIN=<set_frontend_origin>
ALLOWED_ORIGINS=<comma_separated_allowed_origins>

CHATBOT_API_URL=<set_chatbot_api_url>
CHATBOT_API_KEY=<set_chatbot_api_key>
CHATBOT_MODEL=<set_chatbot_model>

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=<set_email_user>
EMAIL_PASS=<set_email_app_password>
OTP_EXPIRES_IN_MINUTES=5
