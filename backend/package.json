{
  "name": "hospital-backend",
  "version": "1.0.0",
  "description": "Hospital Management Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src tests",
    "test": "node --test",
    "test:ci": "node --test",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed --seed 20260308-core-seed-idempotent.js",
    "db:seed:rerun-check": "npm run db:seed && npm run db:seed"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.2",
    "qs": "^6.11.2",
    "sanitize-html": "^2.17.1",
    "sequelize": "^6.37.8",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.2"
  },
  "overrides": {
    "flatted": "^3.4.1"
  }
}
